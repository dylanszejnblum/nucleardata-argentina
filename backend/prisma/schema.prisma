generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DimOperator {
  operatorSlug String @id @map("operator_slug")
  operatorName String @map("operator_name")
  aliases      String

  wells           DimWell[]
  productionFacts FactProductionMonthly[]

  @@map("dim_operator")
}

model DimFormation {
  formationSlug       String  @id @map("formation_slug")
  formationName       String  @map("formation_name")
  formationVacaMuerta Boolean @map("formation_vaca_muerta")

  wells           DimWell[]
  productionFacts FactProductionMonthly[]

  @@map("dim_formation")
}

model DimWell {
  wellId          String @id @map("well_id")
  sigla           String
  operatorSlug    String @map("operator_slug")
  formationSlug   String @map("formation_slug")
  operatorName    String @map("operator_name")
  province        String
  basin           String
  concession      String
  yacimiento      String
  wellType        String @map("well_type")
  extractionType  String @map("extraction_type")
  statusCode      String @map("status_code")
  resourceType    String @map("resource_type")
  subResourceType String @map("sub_resource_type")
  depthM          Float? @map("depth_m")
  latitude        Float?
  longitude       Float?

  operator        DimOperator             @relation(fields: [operatorSlug], references: [operatorSlug])
  formation       DimFormation            @relation(fields: [formationSlug], references: [formationSlug])
  productionFacts FactProductionMonthly[]

  @@index([operatorSlug])
  @@index([formationSlug])
  @@index([province])
  @@index([basin])
  @@map("dim_well")
}

model FactProductionMonthly {
  id             Int      @id @default(autoincrement())
  dateMonth      DateTime @map("date_month") @db.Date
  wellId         String   @map("well_id")
  operatorSlug   String   @map("operator_slug")
  formationSlug  String   @map("formation_slug")
  concession     String
  yacimiento     String
  basin          String
  province       String
  wellType       String   @map("well_type")
  extractionType String   @map("extraction_type")
  statusCode     String   @map("status_code")
  tipoRecurso    String   @map("tipo_recurso")
  depthM         Float?   @map("depth_m")
  coordX         Float?   @map("coord_x")
  coordY         Float?   @map("coord_y")

  oilM3         Float @map("oil_m3")
  gasThousandM3 Float @map("gas_thousand_m3")

  oilBbl   Float @map("oil_bbl")
  oilBblD  Float @map("oil_bbl_d")
  oilBoe   Float @map("oil_boe")
  gasMm3D  Float @map("gas_mm3_d")
  gasMcf   Float @map("gas_mcf")
  gasMmcfD Float @map("gas_mmcf_d")
  gasBoe   Float @map("gas_boe")
  boe      Float

  formationVacaMuerta Boolean @map("formation_vaca_muerta")
  unconventional      Boolean
  vmCombined          Boolean @map("vm_combined")

  well      DimWell      @relation(fields: [wellId], references: [wellId])
  operator  DimOperator  @relation(fields: [operatorSlug], references: [operatorSlug])
  formation DimFormation @relation(fields: [formationSlug], references: [formationSlug])

  @@index([dateMonth, operatorSlug])
  @@index([dateMonth, vmCombined])
  @@index([wellId, dateMonth])
  @@index([formationSlug, dateMonth])
  @@index([operatorSlug])
  @@index([province])
  @@map("fact_production_monthly")
}

model MiningProject {
  id                  Int      @id @default(autoincrement())
  projectName         String   @unique @map("project_name")
  primaryCommodity    String   @map("primary_commodity")
  byProducts          String?  @map("by_products")
  status              String?
  depositType         String?  @map("deposit_type")
  ownerController     String?  @map("owner_controller")
  operator            String?
  areaHa              Float?   @map("area_ha")
  province            String?
  country             String?
  latitude            Float?
  longitude           Float?
  sinceProduction     Int?     @map("since_production")
  estimatedLomYears   Int?     @map("estimated_lom_years")
  productiveCapacity  String?  @map("productive_capacity")
  estimatedAnnualProd String?  @map("estimated_annual_production")
  capex               String?
  miningMethod        String?  @map("mining_method")
  product             String?
  sourcePipeline      String?  @map("source_pipeline")
  resourcesYear       Int?     @map("resources_year")
  ingestedAt          DateTime @default(now()) @map("ingested_at")

  resources Json?
  reserves  Json?
  geology   Json?

  @@index([primaryCommodity])
  @@index([status])
  @@index([province])
  @@map("mining_project")
}

model FactPrice {
  id     Int      @id @default(autoincrement())
  source String
  series String
  name   String
  unit   String
  date   DateTime @db.Date
  value  Float

  @@unique([source, series, date], name: "fact_price_source_series_date")
  @@index([series, date])
  @@index([source, date])
  @@map("fact_price")
}

/// World oil & gas production by country (EIA International) — the reference set
/// used to rank Argentina on the world stage. product = 'oil' | 'gas'.
model FactWorldProduction {
  id      Int      @id @default(autoincrement())
  product String // 'oil' (crude, TBPD) | 'gas' (dry gas, BCF)
  iso3    String
  country String
  period  DateTime @db.Date // annual → YYYY-01-01
  value   Float
  unit    String

  @@unique([product, iso3, period], name: "fact_world_production_product_iso3_period")
  @@index([product, period])
  @@map("fact_world_production")
}

/// RIGI projects (Régimen de Incentivo para Grandes Inversiones), oil & gas only.
/// Compiled from the official Ministerio de Economía registry — provenance per row.
/// sector = 'petroleo' | 'gas'. investmentMusd = committed investment, US$ millions.
model RigiProject {
  id             Int       @id @default(autoincrement())
  name           String    @unique
  sector         String
  operator       String?
  province       String?
  investmentMusd Float?    @map("investment_musd")
  approvalDate   DateTime? @map("approval_date") @db.Date
  sourceLabel    String?   @map("source_label")
  sourceUrl      String?   @map("source_url")

  @@index([sector])
  @@map("rigi_project")
}

model FactRigCount {
  date      DateTime @id @db.Date
  oilRigs   Int?     @map("oil_rigs")
  gasRigs   Int?     @map("gas_rigs")
  totalRigs Int?     @map("total_rigs")

  @@map("fact_rig_count")
}

model FactEnergyBalance {
  id             Int     @id @default(autoincrement())
  ano            Int
  formaDeEnergia String  @map("forma_de_energia")
  concepto       String
  ktepRedond     Float   @map("ktep_redond")

  @@unique([ano, formaDeEnergia, concepto])
  @@index([formaDeEnergia, ano])
  @@index([concepto, ano])
  @@map("fact_energy_balance")
}

/// INDEC Intercambio Comercial Argentino (ICA) — energy trade in USD.
/// Monthly rows carry the surplus (exports − imports); annual rows add agro
/// exports for the agro-vs-energy crossover. Seeded from the pipeline's
/// fact_energy_trade.csv via upsert (idempotent, no TRUNCATE).
model FactEnergyTrade {
  id               Int      @id @default(autoincrement())
  period           DateTime @map("period") @db.Date
  granularity      String // "monthly" | "annual"
  energyExportsUsd Float?   @map("energy_exports_usd")
  energyImportsUsd Float?   @map("energy_imports_usd")
  energySurplusUsd Float?   @map("energy_surplus_usd")
  agroExportsUsd   Float?   @map("agro_exports_usd")
  sourceLabel      String   @map("source_label")
  sourceUrl        String?  @map("source_url")
  sourceAsOf       String?  @map("source_as_of")

  @@unique([period, granularity])
  @@index([granularity, period])
  @@map("fact_energy_trade")
}

model FactFuelPrice {
  id             Int      @id @default(autoincrement())
  fechaVigencia  DateTime @map("fecha_vigencia")
  provincia      String
  localidad      String?
  empresa        String?
  empresaBandera String?  @map("empresa_bandera")
  producto       String
  precio         Float
  tipoHorario    String?  @map("tipo_horario")
  latitude       Float?
  longitude      Float?

  @@index([provincia, producto])
  @@index([fechaVigencia])
  @@index([producto, fechaVigencia])
  @@map("fact_fuel_price")
}

model UraniumProject {
  id           Int      @id @default(autoincrement())
  projectName  String   @unique @map("project_name")
  latitude     Float?
  longitude    Float?
  province     String?
  provinceCode String?  @map("province_code")
  status       String?
  statusLabel  String?  @map("status_label")
  mineral      String   @default("Uranio")
  controllers  Json?
  ingestedAt   DateTime @default(now()) @map("ingested_at")

  @@index([province])
  @@index([status])
  @@map("uranium_project")
}

model UraniumPrice {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  priceUsd  Float    @map("price_usd")
  unit      String   @default("USD/lb")
  year      Int?
  month     Int?
  source    String   @default("siacam")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([source, date], name: "uranium_price_source_date")
  @@index([date])
  @@map("uranium_price")
}

model UraniumTrade {
  id        Int      @id @default(autoincrement())
  year      Int
  month     Int
  tradeType String   @map("trade_type")
  country   String
  valueUsd  Float    @map("value_usd")
  source    String   @default("siacam")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([year, tradeType])
  @@map("uranium_trade")
}

model UraniumFact {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  label     String
  unit      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("uranium_fact")
}

model AggMonthlyByOperator {
  id            Int      @id @default(autoincrement())
  dateMonth     DateTime @map("date_month") @db.Date
  operatorSlug  String   @map("operator_slug")
  operatorName  String   @map("operator_name")
  concession    String
  yacimiento    String
  province      String
  formationSlug String   @map("formation_slug")
  vmCombined    Boolean  @map("vm_combined")
  oilM3         Float    @map("oil_m3")
  oilBbl        Float    @map("oil_bbl")
  oilBblD       Float    @map("oil_bbl_d")
  gasThousandM3 Float    @map("gas_thousand_m3")
  gasMm3D       Float    @map("gas_mm3_d")
  gasMcf        Float    @map("gas_mcf")
  gasMmcfD      Float    @map("gas_mmcf_d")
  boe           Float
  activeWells   Int      @map("active_wells")

  @@index([dateMonth, operatorSlug])
  @@index([dateMonth, vmCombined])
  @@map("agg_monthly_by_operator")
}

model Company {
  slug               String   @id
  name               String
  type               String // "mining" | "oil_and_gas" | "both"
  sector             String // "mining" | "petroleum" | "both"
  country            String?
  website            String?
  logoUrl            String?  @map("logo_url")
  stockTicker        String?  @map("stock_ticker")
  stockExchange      String?  @map("stock_exchange")
  isPublic           Boolean  @default(false) @map("is_public")
  commoditySlugs     String[] @map("commodities")
  provinces          String[]
  projectCountOilGas Int      @default(0) @map("project_count_oil_gas")
  projectCountMining Int      @default(0) @map("project_count_mining")
  oilProductionM3    Float?   @map("oil_production_m3")
  gasProductionM3    Float?   @map("gas_production_m3")
  boeTotal           Float?   @map("boe_total")
  ingestedAt         DateTime @default(now()) @map("ingested_at")

  @@index([type])
  @@index([isPublic])
  @@map("company")
}

model ProvinceExport {
  id             Int      @id @default(autoincrement())
  slug           String
  provinceName   String   @map("province_name")
  sector         String // "petroleo" | "gas" | "mineria" | "agro"
  productName    String   @map("product_name")
  valueAnnualUsd Float    @map("value_annual_usd")
  ingestedAt     DateTime @default(now()) @map("ingested_at")

  @@unique([slug, sector, productName])
  @@index([slug])
  @@map("province_export")
}

model NewsDocument {
  docId           String    @id @map("doc_id")
  sourceName      String    @map("source_name")
  sourceFamily    String    @map("source_family")
  sourceType      String    @map("source_type")
  sourceUrl       String    @map("source_url")
  discoveredVia   String?   @map("discovered_via")
  retrievedAt     DateTime  @map("retrieved_at")
  publishedAt     DateTime? @map("published_at")
  eventDate       DateTime? @map("event_date") @db.Date
  title           String
  deck            String?
  bodyText        String?   @map("body_text")
  language        String    @default("es")
  region          String[]
  geo             Json
  entities        Json
  topics          String[]
  signals         Json
  numbers         Json
  attachments     Json
  clusterId       String?   @map("cluster_id")
  noveltyScore    Float?    @map("novelty_score")
  importanceScore Float?    @map("importance_score")
  legalMode       String    @map("legal_mode")
  editorNotes     String    @default("") @map("editor_notes")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([publishedAt])
  @@index([sourceFamily])
  @@index([clusterId])
  @@index([legalMode])
  @@map("news_document")
}

// Newsletter subscribers. Email is unique (dedup at the DB level); only the
// minimum is stored (email + capture source + timestamps) for privacy.
model NewsletterSubscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  source    String   @default("newsletter-modal")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("newsletter_subscriber")
}

// ──────────────────────────────────────────────
// Argentina Nuclear — atlas models
// ──────────────────────────────────────────────

/// Nuclear power reactors and research reactors in Argentina.
model Reactor {
  id                String    @id // "atucha-i", "embalse", "carem-25", "ra-1", etc.
  name              String
  type              String    // "PHWR" | "CANDU" | "CAREM" | "pool" | "tanque"
  status            String    // "operational" | "construction" | "shutdown" | "decommissioned"
  category          String    @default("power") // "power" | "research" | "prototype"
  latitude          Float?
  longitude         Float?
  province          String?
  city              String?
  capacityMwe       Float?    @map("capacity_mwe")
  capacityMwt       Float?    @map("capacity_mwt")
  firstCriticality  DateTime? @map("first_criticality")
  gridConnection    DateTime? @map("grid_connection")
  operator          String?
  owner             String?
  supplier          String?
  fuelType          String?   @map("fuel_type")
  coolant           String?
  moderator         String?
  lifetimeFactor    Float?    @map("lifetime_factor")
  statusDetail      String?   @map("status_detail")
  sourceUrl         String?   @map("source_url")
  ingestedAt        DateTime  @default(now()) @map("ingested_at")

  @@index([status])
  @@index([province])
  @@index([type])
  @@map("reactor")
}

/// Atomic centers, research institutes, and technological complexes.
model AtomicCenter {
  id          String   @id // "cab", "cae", "cac", "pilcaniyeu", "ib", "is", "iben"
  name        String
  type        String   // "atomic_center" | "institute" | "complex"
  latitude    Float?
  longitude   Float?
  province    String?
  city        String?
  founded     Int?
  operator    String   @default("CNEA")
  focusAreas  Json?    @map("focus_areas")
  facilities  Json?
  website     String?
  ingestedAt  DateTime @default(now()) @map("ingested_at")

  @@index([type])
  @@index([province])
  @@map("atomic_center")
}

/// Medical and industrial radioisotopes produced in Argentina.
model Isotope {
  id                  String   @id // "mo-99", "co-60", "i-131"
  name                String
  type                String   // "medical" | "industrial"
  producer            String   @default("CNEA")
  productionCapacity  String?  @map("production_capacity")
  exportDestinations  Json?    @map("export_destinations")
  domesticConsumption Float?   @map("domestic_consumption")
  globalMarketShare   Float?   @map("global_market_share")
  status              String   @default("active") // "active" | "expanding" | "planned"
  description         String?
  sourceUrl           String?  @map("source_url")
  ingestedAt          DateTime @default(now()) @map("ingested_at")

  @@index([type])
  @@index([status])
  @@map("isotope")
}

/// Historical milestones for the timeline / scrollytelling page.
model HistoryMilestone {
  id              Int      @id @default(autoincrement())
  year            Int
  month           Int?
  title           String
  description     String
  significance    String   // "milestone" | "crisis" | "turning_point" | "context"
  category        String   // "institutional" | "technical" | "political" | "international" | "legal"
  relatedEntities Json?    @map("related_entities")
  sources         Json?
  mediaUrl        String?  @map("media_url")
  ingestedAt      DateTime @default(now()) @map("ingested_at")

  @@index([year])
  @@index([category])
  @@index([significance])
  @@map("history_milestone")
}

/// Per-province nuclear / uranium legislation status (for the "No Nuclear" heatmap).
model ProvinceNuclearStatus {
  province        String   @id
  provinceCode    String   @map("province_code")
  nuclearAllowed  Boolean  @map("nuclear_allowed")
  uraniumAllowed  Boolean? @map("uranium_allowed")
  restrictionType String?  @map("restriction_type") // "constitutional" | "legal" | "ordinance" | "none"
  legislationRef  String?  @map("legislation_ref")
  notes           String?
  ingestedAt      DateTime @default(now()) @map("ingested_at")

  @@map("province_nuclear_status")
}
